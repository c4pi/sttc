# Copy to .env and adjust values for your environment. Do not commit .env.

APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO

# Cloud STT model. Leave empty to use local faster-whisper fallback.
STT_MODEL=
# Optional cloud API key for STT_MODEL providers and clipboard text processing.
OPENAI_API_KEY=
STT_CHUNK_SECONDS=15
STT_WHISPER_MODEL=base
# Default model for refine, summary, and translation.
REFINE_MODEL=gpt-4.1-mini
# Optional cache location for local faster-whisper models.
STT_MODEL_CACHE_DIR=
SAMPLE_RATE_TARGET=16000
CHANNELS=1
RECORDING_MODE=toggle
RECORDING_HOTKEY=ctrl+alt+a
REFINE_HOTKEY=ctrl+alt+r
RECORD_AND_REFINE_HOTKEY=ctrl+alt+w
SUMMARY_HOTKEY=ctrl+alt+s
TRANSLATION_HOTKEY=ctrl+alt+t
QUIT_HOTKEY=ctrl+alt+q

# GUI behavior
ENABLE_GUI=false
GUI_START_MINIMIZED=false

# Written by first-run setup in bundled mode.
AUTO_START_ENABLED=
