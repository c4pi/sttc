# Copy to .env and adjust values for your environment. Do not commit .env.

APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO

# Cloud STT model. Leave empty to use local faster-whisper fallback.
STT_MODEL=
# Optional cloud API key for STT_MODEL providers (for example OpenAI).
OPENAI_API_KEY=
STT_CHUNK_SECONDS=15
STT_WHISPER_MODEL=base
# Optional cache location for local faster-whisper models.
STT_MODEL_CACHE_DIR=
SAMPLE_RATE_TARGET=16000
CHANNELS=1
RECORDING_MODE=toggle
RECORDING_HOTKEY=ctrl+shift
QUIT_HOTKEY=ctrl+alt+q
# Written by first-run setup in bundled mode.
AUTO_START_ENABLED=
