# Copy to .env and adjust. Do not commit .env.
# See settings.py for Pydantic BaseSettings fields.

APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# Optional: add project-specific env vars below
GEMINI_API_KEY=your_api_key_here
TRANSCRIPTION_BACKEND=gemini
REFINEMENT_PROVIDER=ollama
USE_REFINEMENT=false
GEMINI_REFINEMENT_MODEL=gemini/gemini-2.5-flash
OLLAMA_REFINEMENT_MODEL=ollama/qwen3:4b
GEMINI_STT_MODEL=models/gemini-2.5-flash
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
GEMINI_TTS_VOICE=Kore
USE_TTS=true